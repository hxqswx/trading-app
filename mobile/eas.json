{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://trading-app-khaki-three.vercel.app"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "ios": { "buildConfiguration": "Release" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://trading-app-khaki-three.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
